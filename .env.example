# Copie este archivo como .env.local. No publique .env.local.
ADMIN_PASSWORD=cambie-esta-clave-por-una-frase-larga

# Hoja maestra privada, usada solo por el servidor administrativo local.
GOOGLE_SHEET_ID=id_de_la_hoja_maestra_privada

# Opcional: hoja pública separada, sin nombres, teléfonos ni correos.
# Si se omite, la versión de GitHub Pages usa el respaldo agregado incluido.
VITE_GOOGLE_SHEET_ID=id_de_la_hoja_publica_anonimizada

PORT=4173
